# Caddyfile — TLS terminator + reverse proxy for the harness deploy box.
#
# Topology after flipping:
#   internet :443 → caddy → 127.0.0.1:6755   ai-note
#                        → 127.0.0.1:6743   ai-ledger
#                        → 127.0.0.1:????   trade        (fill in)
#
# Caddy auto-fetches Let's Encrypt certs on first reload via the HTTP-01
# challenge (it owns :80 itself, no certbot needed). Renews 30 days before
# expiry. Just keep :80 + :443 reachable from the internet.
#
# Rollout (see ./install.sh):
#   1. Buy domain (e.g. superleo.app) and point note. / ledger. A records
#      at the box.
#   2. Open :80 and :443 in the cloud security group.
#   3. ./install.sh  (installs caddy from official apt repo + drops this
#      Caddyfile + reloads).
#   4. Verify https://note.<your-domain>/api/info returns JSON.
#   5. Flip the upstream apps to bind 127.0.0.1 instead of 0.0.0.0 (edit
#      their systemd units, change --bind, daemon-reload + restart). After
#      that the only public ports are :80 + :443.

{
    # Operator email — ACME registers under this; gets cert-expiry warnings.
    email ll_faw@hotmail.com

    # Comment the line below out for production. With it on you hit LE's
    # staging environment, which issues untrusted certs (browser warning)
    # but doesn't count against the LE production rate limit. Useful for
    # the first end-to-end smoke; flip off once it works.
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# Replace `superleo.app` with whatever you actually buy. The placeholder
# is here so the file is `caddy validate`-clean as-shipped.
(common) {
    encode zstd gzip
    # Agent chat history + zip export response both can be a few MB; 50MB
    # cap is generous on both sides.
    request_body {
        max_size 50MB
    }
    # Long agent loops occasionally exceed the default 30s idle. Bump
    # both halves of the proxy to 2min. Tune up if you stream LLM output.
    reverse_proxy {
        transport http {
            read_timeout  2m
            write_timeout 2m
        }
    }
}

# ── ai-note ──────────────────────────────────────────────────────
note.superleo.app {
    import common
    reverse_proxy 127.0.0.1:6755
}

# ── ai-ledger ────────────────────────────────────────────────────
ledger.superleo.app {
    import common
    reverse_proxy 127.0.0.1:6743
}

# ── trade (placeholder — fill in upstream port + uncomment) ──────
# trade.superleo.app {
#     import common
#     reverse_proxy 127.0.0.1:PORT
# }

# Optional: catch-all that 444s any unknown Host so port scanners get
# nothing useful. Comment this out if you'd rather Caddy serve a default
# 404 page.
:80, :443 {
    abort
}
