# Caddyfile — TLS terminator + reverse proxy for the harness deploy box.
#
# Topology after flipping:
#   internet :443 → caddy → 127.0.0.1:6755   ai-note
#                        → 127.0.0.1:????   trade        (fill in)
#
# Caddy auto-fetches Let's Encrypt certs on first reload via the HTTP-01
# challenge (it owns :80 itself, no certbot needed). Renews 30 days before
# expiry. Just keep :80 + :443 reachable from the internet.
#
# Rollout (see ./install.sh):
#   1. Buy domain (e.g. superleo.app) and point note. / ledger. A records
#      at the box.
#   2. Open :80 and :443 in the cloud security group.
#   3. ./install.sh  (installs caddy from official apt repo + drops this
#      Caddyfile + reloads).
#   4. Verify https://note.<your-domain>/api/info returns JSON.
#   5. Flip the upstream apps to bind 127.0.0.1 instead of 0.0.0.0 (edit
#      their systemd units, change --bind, daemon-reload + restart). After
#      that the only public ports are :80 + :443.

{
    # Operator email — ACME registers under this; gets cert-expiry warnings.
    email ll_faw@hotmail.com

    # Uncomment to hit LE's staging environment (issues untrusted certs but
    # doesn't count against the production rate limit — useful for the
    # first end-to-end smoke if you're poking).
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

# Reusable proxy block. Usage: `import site UPSTREAM:PORT`.
# Long-running agent loops occasionally exceed Caddy's default 30s idle;
# bumping both halves to 2m so chat replies that touch DeepSeek + tools
# don't get cut off mid-thought.
(site) {
    encode zstd gzip
    request_body {
        max_size 50MB
    }
    reverse_proxy {args[0]} {
        transport http {
            read_timeout  2m
            write_timeout 2m
        }
    }
}

# ── ai-note ──────────────────────────────────────────────────────
note.superleo.app {
    import site 127.0.0.1:6755
}

# ── trade (placeholder — fill in upstream port + uncomment) ──────
# trade.superleo.app {
#     import site 127.0.0.1:PORT
# }

# ── me (personal portfolio — STATIC, no upstream app) ────────────
# Not a reverse proxy: Caddy serves the single self-contained index.html
# straight off disk. Drop the page at /var/www/me/index.html (same file as
# the liliang-cn.github.io homepage / liliang-cn-site project).
# CSP intentionally allows 'unsafe-inline' because the page inlines its own
# CSS + the theme-toggle script; external origins are just Google Fonts and
# the GitHub avatar (favicon / og:image).
me.superleo.app {
    root * /var/www/me
    encode zstd gzip

    header {
        -Server
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "geolocation=(), microphone=(), camera=()"
        Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' https://github.com https://*.githubusercontent.com data:; script-src 'self' 'unsafe-inline'; base-uri 'self'; frame-ancestors 'none'"
    }

    file_server
}
